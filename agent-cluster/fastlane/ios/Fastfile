# iOS Fastlane 配置

default_platform(:ios)

platform :ios do
  desc "运行测试"
  lane :test do
    scan(
      scheme: "App",
      device: "iPhone 15"
    )
  end

  desc "构建 Beta 版本并上传到 TestFlight"
  lane :beta do
    # 确保使用正确的 Xcode 版本
    select_xcode_scheme(
      scheme: "App"
    )
    
    # 获取证书和配置文件
    match(
      type: "appstore",
      readonly: true
    )
    
    # 构建 IPA
    build_app(
      workspace: "App.xcworkspace",
      scheme: "App",
      export_method: "app-store"
    )
    
    # 上传到 TestFlight
    upload_to_testflight(
      username: ENV["APP_STORE_CONNECT_USERNAME"],
      api_key: {
        key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
        issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
        key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"]
      },
      changelog: changelog_from_git_commits(
        between: ["#{ENV['FASTLANE_LAST_COMMIT']}", "HEAD"],
        pretty: "- %s",
        include_merges: false
      )
    )
  end

  desc "发布到 App Store"
  lane :release do
    match(type: "appstore")
    
    build_app(
      workspace: "App.xcworkspace",
      scheme: "App",
      export_method: "app-store"
    )
    
    upload_to_app_store(
      username: ENV["APP_STORE_CONNECT_USERNAME"],
      api_key: {
        key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
        issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
        key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"]
      },
      skip_binary_upload: false,
      skip_metadata: true,
      skip_screenshots: true
    )
  end

  desc "管理证书"
  lane :certificates do
    match(type: "development")
    match(type: "distribution")
    match(type: "appstore")
  end
end
