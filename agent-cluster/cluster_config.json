{
  "cluster": {
    "name": "openclaw-codex-cluster",
    "version": "2.0",
    "mode": "orchestrator",
    "max_parallel_agents": 3,
    "timeout_seconds": 300,
    "memory_optimization": {
      "shared_node_modules": "~/.openclaw/shared/node_modules",
      "cleanup_interval_hours": 24,
      "task_retention_days": 7
    }
  },
  "orchestrator": {
    "id": "zoe",
    "name": "Zoe 编排者",
    "workspace": "~/.openclaw/workspace/zoe",
    "model": {
      "provider": "alibaba-cloud",
      "model": "qwen-max",
      "temperature": 0.7,
      "max_tokens": 4096
    },
    "role": "orchestrator",
    "skills": [
      "task_decomposition",
      "agent_selection",
      "prompt_engineering",
      "failure_analysis",
      "context_management"
    ],
    "mcp_servers": ["obsidian", "memory", "database", "dingtalk"],
    "enabled": true
  },
  "github": {
    "token": "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",
    "user": "phoenixbull",
    "repo": "agent-cluster-test",
    "branch_prefix": "agent/",
    "auto_create_pr": true,
    "auto_merge": false,
    "require_ci": true
  },
  "agents": [
    {
      "id": "codex",
      "name": "Codex 后端专家",
      "workspace": "~/.openclaw/workspace/agents/codex",
      "model": {
        "provider": "alibaba-cloud",
        "model": "qwen-coder-plus",
        "temperature": 0.3,
        "max_tokens": 8192
      },
      "role": "backend_specialist",
      "skills": [
        "backend_logic",
        "bug_fixing",
        "refactoring",
        "cross_file_reasoning",
        "api_design"
      ],
      "mcp_servers": ["filesystem", "github", "database"],
      "enabled": true,
      "task_types": ["backend_logic", "bug_fix", "refactoring", "api_design", "database"],
      "weight": 0.9
    },
    {
      "id": "claude-code",
      "name": "Claude Code 前端专家",
      "workspace": "~/.openclaw/workspace/agents/claude-code",
      "model": {
        "provider": "alibaba-cloud",
        "model": "qwen-plus",
        "temperature": 0.5,
        "max_tokens": 4096
      },
      "role": "frontend_specialist",
      "skills": [
        "frontend_development",
        "git_operations",
        "component_development",
        "rapid_iteration"
      ],
      "mcp_servers": ["filesystem", "github"],
      "enabled": true,
      "task_types": ["frontend", "ui_component", "git_operation", "quick_fix"],
      "weight": 0.7
    },
    {
      "id": "designer",
      "name": "设计专家 (Gemini)",
      "workspace": "~/.openclaw/workspace/agents/designer",
      "model": {
        "provider": "alibaba-cloud",
        "model": "qwen-vl-plus",
        "temperature": 0.6,
        "max_tokens": 4096
      },
      "role": "design_specialist",
      "skills": [
        "ui_design",
        "wireframe",
        "prototype",
        "design_system",
        "visual_system",
        "html_css",
        "design_spec"
      ],
      "mcp_servers": ["figma", "excalidraw", "filesystem"],
      "enabled": true,
      "task_types": ["ui_design", "visual", "html_css", "design_spec", "mockup", "prototype"],
      "weight": 0.6,
      "v2_merged": true,
      "v1_compatible": true
    }
  ],
  "reviewers": [
    {
      "id": "codex-reviewer",
      "name": "Codex 审查者",
      "model": "qwen-coder-plus",
      "focus": "边界情况、逻辑错误、竞态条件",
      "weight": "high",
      "required": true
    },
    {
      "id": "gemini-reviewer",
      "name": "Gemini 审查者",
      "model": "qwen-plus",
      "focus": "安全问题、扩展性、代码质量",
      "weight": "medium",
      "required": true
    },
    {
      "id": "claude-reviewer",
      "name": "Claude 审查者",
      "model": "qwen-turbo",
      "focus": "基础检查（仅 critical 问题）",
      "weight": "low",
      "required": false
    }
  ],
  "protocols": {
    "mcp": {
      "enabled": true,
      "servers": [
        "obsidian",
        "memory",
        "filesystem",
        "github",
        "database",
        "dingtalk",
        "figma",
        "excalidraw"
      ],
      "timeout_seconds": 30
    },
    "a2a": {
      "enabled": true,
      "port": 5000,
      "timeout_seconds": 60
    },
    "anp": {
      "enabled": false,
      "discovery_interval_seconds": 30
    }
  },
  "workflows": {
    "ralph_loop": {
      "enabled": true,
      "max_retries": 3,
      "learning_enabled": true,
      "memory_path": "~/.openclaw/workspace/zoe/memory"
    },
    "monitoring": {
      "enabled": true,
      "interval_minutes": 10,
      "check_items": ["tmux_session", "pr_status", "ci_status", "review_status"]
    },
    "ci_cd": {
      "enabled": true,
      "github_repo": "phoenixbull/agent-cluster-test",
      "required_checks": ["lint", "typecheck", "tests", "e2e"],
      "review_requirements": {
        "codex_reviewer_approved": true,
        "gemini_reviewer_approved": true,
        "screenshots_for_ui_changes": true
      }
    }
  },
  "tools": {
    "builtin": ["search", "calculator", "memory", "diagram", "dingtalk"],
    "mcp": ["obsidian", "memory", "filesystem", "github", "database", "dingtalk", "figma", "excalidraw"]
  },
  "notifications": {
    "dingtalk": {
      "enabled": true,
      "webhook": "https://oapi.dingtalk.com/robot/send?access_token=3c5282dc6240317a2c1e8677cee449384aeeee6c6accf066c5dcfbcb944eebea",
      "secret": "SEC34882f15108eb1d6ec9e780b991bc32440398ef284b1f72022e772972932fc6e",
      "events": [
        "task_complete",
        "task_failed",
        "pr_ready",
        "human_intervention_needed",
        "daily_summary",
        "cluster_status"
      ],
      "at_all": {
        "task_complete": false,
        "task_failed": true,
        "pr_ready": false,
        "human_intervention_needed": true,
        "daily_summary": false,
        "cluster_status": false
      }
    },
    "telegram": {
      "enabled": false
    }
  }
}
